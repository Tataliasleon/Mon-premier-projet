body { font-family: 'Inter', sans-serif; background: #0f172a; color: white; margin: 0; }
.container { max-width: 1000px; margin: auto; padding: 20px; }
.card-index { background: #1e293b; border-radius: 12px; padding: 20px; box-shadow: 0 10px 25px rgba(0,0,0,0.3); }
table { width: 100%; border-collapse: collapse; margin-top: 20px; }
th { text-align: left; color: #94a3b8; font-size: 14px; text-transform: uppercase; padding: 15px; }
td { padding: 15px; border-bottom: 1px solid #334155; }
.cote-up { color: #10b981; font-weight: bold; }